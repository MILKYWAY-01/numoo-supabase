rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      // Users can read/write only their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Admin can read users where adminId matches
      allow read: if request.auth != null &&
        resource.data.adminId == request.auth.uid;

      // Usage data subcollection
      match /usageData/{date}/apps/{packageName} {
        // User can read/write own usage data
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Admin can read usage data of linked users
        allow read: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(userId)).data.adminId == request.auth.uid;
      }
    }

    // Limits collection
    match /limits/{userId}/apps/{packageName} {
      // User can read their own limits
      allow read: if request.auth != null && request.auth.uid == userId;

      // Only admin can write limits
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(userId)).data.adminId == request.auth.uid;
    }

    // Notifications collection
    match /notifications/{adminId}/requests/{notifId} {
      // Users can create notifications
      allow create: if request.auth != null;

      // Admin can read their notifications
      allow read: if request.auth != null && request.auth.uid == adminId;

      // Admin can update notification status
      allow update: if request.auth != null && request.auth.uid == adminId;
    }
  }
}
